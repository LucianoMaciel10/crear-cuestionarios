{
  "version": 2,
  "builds": [
    {
      "src": "api/extract-concepts.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/extract-concepts",
      "dest": "api/extract-concepts.ts"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
